# Formspree endpoint for the contact form.
# Sign up at https://formspree.io, create a form, copy the endpoint URL.
# In Vercel: Settings → Environment Variables → Add New
# Key: NEXT_PUBLIC_FORMSPREE_ENDPOINT
# Value: https://formspree.io/f/yourFormId
#
# Without this variable, the form falls back to a graceful error pointing
# visitors to contact@jurryi.com.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/yourFormId
